theme_minimal() +
theme(
legend.position = "none",  # Remove legend
plot.title = element_text(hjust = 0.5)
)
# Create scatter plot
tidyplot <- ggplot(non_outliers, aes(x = observations, y = variables, color = year)) +
geom_point(alpha = 0.5) +
geom_point(data = outliers, aes(x = observations, y = variables, color = year), alpha = 0.5) +
geom_text(data = outliers, aes(x = observations, y = variables, label = observations),
vjust = -0.5, hjust = 1, size = 3, color = "black") +  # Add observation values above outliers
scale_color_manual(values = c("red", "blue", "green", "purple", "orange", "cyan", "pink")) +  # Custom color palette
labs(
title = "Observations vs Variables",
x = "Observations",
y = "Variables",
color = "Year"
) +
theme_minimal() +
theme(
legend.position = "none",  # Remove legend
plot.title = element_text(hjust = 0.5)
)
